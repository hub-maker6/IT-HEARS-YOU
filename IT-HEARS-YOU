--[[
    IT HEARS YOU UNLOCK ALL ITEMS
    Key System GUI
    ---------------------------------------------------
    HOW TO SET YOUR LINK:
    Find the line below that looks like:
        local KEY_LINK = "[PASTE-YOUR-KEY-LINK-HERE]"
    Replace the text inside the quotes with your real
    key/link (e.g. a Linkvertise or Lootlabs link).
    You can change it any time — just edit that one line.
    ---------------------------------------------------
    HOW TO SET YOUR VALID KEY(S):
    Edit the VALID_KEYS table near the top to include
    whatever key string(s) should unlock the script.
--]]
 
local Players = game:GetService("Players")
