-- Hover feedback
local function hoverFX(btn, baseColor, hoverColor)
    btn.MouseEnter:Connect(function()
        tween(btn, {BackgroundColor3 = hoverColor}, 0.15)
    end)
    btn.MouseLeave:Connect(function()
        tween(btn, {BackgroundColor3 = baseColor}, 0.15)
    end)
end
 
hoverFX(CheckKeyBtn, Color3.fromRGB(90, 70, 255), Color3.fromRGB(110, 90, 255))
hoverFX(CopyLinkBtn, Color3.fromRGB(35, 35, 44), Color3.fromRGB(48, 48, 60))
 
-- ==================== LOGIC ====================
 
-- Copy Link button: copies KEY_LINK to clipboard (executor function if available)
CopyLinkBtn.MouseButton1Click:Connect(function()
    local ok = false
    if setclipboard then
        ok = pcall(setclipboard, KEY_LINK)
    elseif toclipboard then
        ok = pcall(toclipboard, KEY_LINK)
    end
 
    if ok then
        Status.Text = "Link copied to clipboard!"
        Status.TextColor3 = Color3.fromRGB(120, 230, 150)
    else
        -- Fallback: put the link in the key box so it can be selected/copied manually
        KeyBox.Text = KEY_LINK
        Status.Text = "Clipboard unavailable — link placed in the box above"
        Status.TextColor3 = Color3.fromRGB(230, 200, 120)
    end
end)
 
-- Check Key button: validates entered text against VALID_KEYS
local function isValidKey(input)
    for _, k in ipairs(VALID_KEYS) do
        if input == k then
            return true
        end
    end
    return false
end
 
CheckKeyBtn.MouseButton1Click:Connect(function()
    local entered = KeyBox.Text
 
    if entered == "" then
        Status.Text = "Please enter a key first"
        Status.TextColor3 = Color3.fromRGB(230, 120, 120)
        return
    end
 
    if isValidKey(entered) then
        Status.Text = "Key verified! Unlocking..."
        Status.TextColor3 = Color3.fromRGB(120, 230, 150)
 
        tween(Main, {Size = UDim2.new(0, 400, 0, 240)}, 0.2)
        task.wait(0.6)
 
        -- Fade out and destroy the GUI, then unlock your items here
        tween(Backdrop, {BackgroundTransparency = 1}, 0.3)
        tween(Main, {BackgroundTransparency = 1}, 0.3)
        for _, obj in ipairs(Main:GetDescendants()) do
            if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                tween(obj, {TextTransparency = 1}, 0.3)
            end
            if obj:IsA("Frame") then
                tween(obj, {BackgroundTransparency = 1}, 0.3)
            end
        end
        task.wait(0.35)
        ScreenGui:Destroy()
 
        -- ===============================================
        -- PUT YOUR "UNLOCK ALL ITEMS" CODE BELOW THIS LINE
        -- ===============================================
        print("Key accepted — items unlocked.")
    else
        Status.Text = "Invalid key. Get one using Copy Link."
        Status.TextColor3 = Color3.fromRGB(230, 120, 120)
        tween(KeyBox, {BackgroundColor3 = Color3.fromRGB(60, 25, 25)}, 0.15)
        task.wait(0.25)
        tween(KeyBox, {BackgroundColor3 = Color3.fromRGB(28, 28, 36)}, 0.25)
    end
end)
